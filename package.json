{
  "name": "medicare-patna",
  "version": "1.0.0",
  "description": "MediCare — Patna's premier digital health ecosystem",
  "main": "index.html",
  "scripts": {
    "dev": "npx serve public -p 3000 --no-clipboard",
    "build": "echo 'Static app — no build step needed'",
    "cap:init": "npx @capacitor/cli init MediCare com.medicare.patna --web-dir public",
    "cap:android": "npx @capacitor/cli add android",
    "cap:sync": "npx @capacitor/cli sync",
    "cap:open": "npx @capacitor/cli open android",
    "cap:run": "npx @capacitor/cli run android"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0"
  },
  "keywords": [
    "healthcare",
    "patna",
    "bihar",
    "medicare",
    "ayushman",
    "abha"
  ],
  "author": "MediCare Patna",
  "license": "MIT"
}
